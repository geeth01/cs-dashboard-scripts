# Copy to .env and adjust. Dates are inclusive calendar days (Slack window: 5:00 on START through 5:00 the day after END).

START_DATE=2026-04-10
END_DATE=2026-04-10

# Only build CSV; skip Google Sheets (good for local checks)
# CSV_ONLY=1

# TLS: if you see CERTIFICATE_VERIFY_FAILED on macOS/Python.org, run: pip install certifi
# Or point to your corporate root CA bundle:
# SSL_CERT_FILE=/path/to/cacert.pem
# Last resort (insecure): SLACK_INSECURE_SSL=1

# Optional overrides
# SLACK_BOT_TOKEN=xoxb-your-token
# SLACK_CHANNEL_ID=C0123456789
# SPREADSHEET_ID=your_sheet_id
# CREDENTIALS_PATH=/absolute/path/to/service-account.json

# FY27 thread script (dev11-build-send-cms-table-jenkins-fy27-thread.py) — tab names if different
# SHEET_FY27_STATUS=FY27Status
# SHEET_FY27_FLAKY=FY27Flaky
# SHEET_FY27_BUG_PRODUCT=FY27Bug-Product
# SHEET_FY27_BUG_INFRA=FY27Bug-Infra
# SHEET_FY27_TOTAL_RUNS_NEW=FY27TotalRunsNew

# Seconds to pause between Slack conversations.replies calls (many failures in range)
# SLACK_REPLIES_DELAY_SECONDS=0.25

# Seconds to pause between each report date when updating Sheets (helps avoid 429 read quota)
# SHEETS_API_DELAY_SECONDS=5
