# Copy to .env and fill in values. Never commit .env.

# Date range to scan (inclusive, YYYY-MM-DD)
START_DATE=2026-05-01
END_DATE=2026-06-15

# Output Google Sheet ID (from the URL: /spreadsheets/d/{ID}/edit)
SPREADSHEET_ID=1RNfRR4ZtfKwlahB6lmvUk_sjld1AVfrbHUwDSaW2cWg

# Path to service account JSON (same one used by other scripts in this repo)
CREDENTIALS_PATH=./service-account.json

# AWS S3 credentials — leave blank if bucket allows anonymous access over VPN
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Override bucket name if needed (default: sanity-reports-and-screenshots)
# S3_BUCKET=sanity-reports-and-screenshots

# Seconds to pause between Google Sheets API writes (avoids 429 quota errors)
# SHEETS_API_DELAY_SECONDS=2
